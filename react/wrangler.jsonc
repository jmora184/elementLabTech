{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "elementlab-pages",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-02-05",

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "elementlab-db",
      "database_id": "3af80c02-2d78-49ea-9de2-87001b212d6d"
    }
  ],

  "r2_buckets": [
    {
      "binding": "DOCS_BUCKET",
      "bucket_name": "elementlab-docs"
    }
  ],

  "vars": {
    "ENV": "local"
  }
}
